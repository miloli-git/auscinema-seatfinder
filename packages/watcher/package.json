{
  "name": "@auscinema/watcher",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "auscinema-watch": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "check": "node dist/cli.js check",
    "watch": "node dist/cli.js watch",
    "start": "node dist/cli.js watch",
    "test": "tsc -b && node --test dist/check.test.js"
  },
  "dependencies": {
    "@auscinema/core": "*",
    "@auscinema/adapter-event": "*",
    "@auscinema/adapter-hoyts": "*",
    "@auscinema/adapter-reading": "*",
    "@auscinema/adapter-village": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}

# Single entrypoint: serves the SPA and reverse-proxies the API routes (same-origin).
# The access gate lives here at the proxy layer so it is auth-mechanism-agnostic.
#
# CURRENTLY OPEN (no auth). The Fastify per-IP rate limit still protects the upstream
# cinema calls. To re-gate, add ONE block inside the site below, before the @api matcher:
#   basic_auth {
#     {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}     # hash via `caddy hash-password`; in .env double every $ to $$
#   }
# or, for Authentik later, a `forward_auth authentik-outpost:9000 { ... }` block instead.
# Nothing else in this file or the app changes.
#
# SITE_ADDRESS:  ":8080" for plain HTTP behind a tunnel/upstream proxy, or "seatfinder.example.org"
#                for Caddy to fetch a real cert automatically.
# UPSTREAM_API:  host:port of the api container (default api:3001).

{$SITE_ADDRESS::8080} {
	encode gzip

	# API routes -> Fastify service. Keep in sync with the app's route list.
	# handle blocks are required: without them, the SPA `try_files` below rewrites
	# /cinemas etc. to /index.html in the rewrite phase (which runs before reverse_proxy),
	# so the @api matcher no longer matches and every API call returns the SPA shell.
	@api path /healthz /cinemas /sessions /seatmap /best /movies /together /catalog
	handle @api {
		reverse_proxy {$UPSTREAM_API:api:3001}
	}

	# Everything else: the SPA, with client-side routing fallback.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

# Copy to .env and edit. Never commit your real .env.

# Where Caddy listens. ":8080" = plain HTTP (use behind a tunnel or an upstream proxy that
# terminates TLS). Set to a hostname (e.g. "seatfinder.example.org") for automatic HTTPS.
SITE_ADDRESS=:8080

# Host port the web container is published on (the left side of the mapping).
WEB_PORT=8080

# Interim access gate (one credential). Generate the hash:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
BASIC_AUTH_USER=you
BASIC_AUTH_HASH=

# API per-IP rate limit (protects the upstream cinema backends).
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Only needed for the optional `alerts` (watcher) profile: a Discord/ntfy/Slack-style webhook.
WATCHER_WEBHOOK=

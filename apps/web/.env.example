# --- Web app (client) -------------------------------------------------------
# Base URL the SPA prefixes onto API requests.
# Leave EMPTY to make same-origin requests that the Vite dev/preview proxy (and
# any production reverse proxy) forwards to the API. Only set this to an
# absolute URL if that API serves CORS headers.
VITE_API_BASE=

# --- Dev/preview proxy target (server-side, not shipped to the client) -------
# Where the Vite dev/preview proxy forwards the API routes.
VITE_DEV_API_TARGET=http://localhost:3001
